#!/bin/bash
# validate.sh — Comprehensive deployment validation, rendered by Ansible.
# Works for both local-KVM (BCM on localhost:10022, QEMU MAC) and remote (BCM
# behind a jumphost, physical node with real MAC) by reusing the same SSH
# config pattern as deploy-dd.sh and parameterizing the target node identity.
set -uo pipefail

BCM_HOST="{{ bcm_ssh_host | default('localhost') }}"
BCM_PASSWORD="{{ bcm_password }}"
BCM_SSH_PORT="{{ bcm_ssh_port }}"
BUILD_DIR="{{ build_dir }}"
KAIROS_USER="kairos"
KAIROS_PASSWORD="kairos"
BCM_INTERNAL_IP="{{ bcm_internal_ip }}"
TARGET_NODE="{{ bcm_target_node | default('node001') }}"

mkdir -p "${BUILD_DIR}"
SSH_CONFIG="${BUILD_DIR}/.bcm-ssh-config"
cat > "${SSH_CONFIG}" << SSHCONF
Host bcm-target
    HostName ${BCM_HOST}
    Port ${BCM_SSH_PORT}
    User root
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel ERROR
    ConnectTimeout 10
{% if bcm_ssh_proxy_jump | default('') %}
    ProxyCommand ssh -i {{ bcm_ssh_proxy_key | regex_replace('^~', lookup('env', 'HOME')) }} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -W %h:%p {{ bcm_ssh_proxy_jump }}
{% endif %}
SSHCONF
chmod 600 "${SSH_CONFIG}"

SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o ConnectTimeout=10"
BCM_SSH="sshpass -p ${BCM_PASSWORD} ssh -F ${SSH_CONFIG} bcm-target"

filter_motd() { grep -vE "cmfirstboot is still in progress|^$|Welcome to|Documentation|Management|Support|updates is more|sudo apt update|Base Command Manager|Cluster Manager ID|module|Use the following|initadd|module add|^-----|^$" || true; }

PASS=0; FAIL=0; WARN=0
check() {
    local name="$1" result="$2" detail="${3:-}"
    if [[ "$result" == "PASS" ]]; then PASS=$((PASS+1))
    elif [[ "$result" == "WARN" ]]; then WARN=$((WARN+1))
    else FAIL=$((FAIL+1)); fi
    if [[ -n "$detail" ]]; then echo "  [${result}] ${name} — ${detail}"
    else echo "  [${result}] ${name}"; fi
}

echo "============================================"
echo " E2E Deployment Validation (KVM)"
echo "============================================"
echo ""

# =============================================
# BCM HEAD NODE
# =============================================
echo "== BCM Head Node (port ${BCM_SSH_PORT}) =="
echo ""

echo "-- Connectivity --"
${BCM_SSH} "echo ok" &>/dev/null && check "BCM SSH" "PASS" "port ${BCM_SSH_PORT}" || { check "BCM SSH" "FAIL" "Cannot reach BCM"; exit 1; }

echo ""
echo "-- BCM Services --"
CMD_STATUS=$(${BCM_SSH} "systemctl is-active cmd 2>/dev/null" 2>/dev/null | filter_motd)
[[ "$CMD_STATUS" == "active" ]] && check "cmd service" "PASS" "" || check "cmd service" "FAIL" "$CMD_STATUS"

DHCPD_STATUS=$(${BCM_SSH} "systemctl is-active dhcpd 2>/dev/null" 2>/dev/null | filter_motd)
[[ "$DHCPD_STATUS" == "active" ]] && check "dhcpd" "PASS" "" || check "dhcpd" "FAIL" ""

NAMED_STATUS=$(${BCM_SSH} "systemctl is-active named 2>/dev/null" 2>/dev/null | filter_motd)
[[ "$NAMED_STATUS" == "active" ]] && check "named (DNS)" "PASS" "" || check "named" "FAIL" ""

NFS_STATUS=$(${BCM_SSH} "systemctl is-active nfs-server 2>/dev/null" 2>/dev/null | filter_motd)
[[ "$NFS_STATUS" == "active" ]] && check "nfs-server" "PASS" "" || check "nfs-server" "FAIL" ""

RSYNC_LISTEN=$(${BCM_SSH} "ss -tlnp 2>/dev/null | grep :873 | head -1" 2>/dev/null | filter_motd)
[[ -n "$RSYNC_LISTEN" ]] && check "rsyncd (873)" "PASS" "" || check "rsyncd (873)" "WARN" ""

HTTP_LISTEN=$(${BCM_SSH} "ss -tlnp 2>/dev/null | grep :8888 | head -1" 2>/dev/null | filter_motd)
[[ -n "$HTTP_LISTEN" ]] && check "HTTP server (8888)" "PASS" "Kairos image server" || check "HTTP server (8888)" "FAIL" ""

echo ""
echo "-- BCM Connectivity --"
${BCM_SSH} "ping -c1 -W3 localhost" &>/dev/null && check "BCM ping" "PASS" "" || check "BCM ping" "FAIL" ""

echo ""
echo "-- BCM Network --"
# BCM's internal IP may be on eth0 (local-KVM with net.ifnames=0) or enp*/ens* (remote).
# Match by IP, not interface name.
INT_IF=$(${BCM_SSH} "ip -4 -o addr 2>/dev/null | awk -v ip='${BCM_INTERNAL_IP}' '\$4 ~ \"^\"ip\"/\" {print \$2; exit}'" 2>/dev/null | filter_motd | tr -d '[:space:]')
[[ -n "$INT_IF" ]] && check "BCM internal IP" "PASS" "${BCM_INTERNAL_IP} on ${INT_IF}" || check "BCM internal IP" "FAIL" "${BCM_INTERNAL_IP} not on any BCM interface"

{% if bcm_manage_dns | default(true) %}
# Local-KVM / fresh-BCM only: check eth1 (BCM's external NAT interface).
# Remote BCMs use ens*/enp* names and may not route internet through themselves.
ETH1_IP=$(${BCM_SSH} "ip -4 addr show eth1 2>/dev/null | grep -oP 'inet \K[0-9.]+'" 2>/dev/null | filter_motd)
[[ -n "$ETH1_IP" ]] && check "eth1 (external)" "PASS" "$ETH1_IP" || check "eth1 (external)" "FAIL" "no IP on eth1"
{% else %}
EXT_IF=$(${BCM_SSH} "ip -o route 2>/dev/null | awk '/^default/{print \$5; exit}'" 2>/dev/null | filter_motd)
[[ -n "$EXT_IF" ]] && check "BCM external iface" "PASS" "$EXT_IF" || check "BCM external iface" "WARN" "no default route"
{% endif %}

IP_FWD=$(${BCM_SSH} "cat /proc/sys/net/ipv4/ip_forward" 2>/dev/null | filter_motd)
[[ "$IP_FWD" == "1" ]] && check "IP forwarding" "PASS" "" || check "IP forwarding" "WARN" "disabled — compute nodes may lack internet"

echo ""
echo "-- BCM DNS --"
DNS_EXT=$(${BCM_SSH} "host google.com 2>/dev/null | head -1" 2>/dev/null | filter_motd)
echo "$DNS_EXT" | grep -q "has address" && check "External DNS" "PASS" "" || check "External DNS" "FAIL" "$DNS_EXT"

INET=$(${BCM_SSH} 'curl -sk -o /dev/null -w "%{http_code}" --connect-timeout 15 --max-time 20 https://google.com 2>/dev/null' 2>/dev/null | filter_motd)
[[ "$INET" == "301" || "$INET" == "200" ]] && check "Internet access" "PASS" "HTTP $INET" || check "Internet access" "WARN" "HTTP ${INET:-timeout}"

echo ""
echo "-- BCM Cluster --"
CMSH_LIST=$(${BCM_SSH} "cmsh -c 'device; list' 2>/dev/null" 2>/dev/null | filter_motd)
echo "$CMSH_LIST" | grep -q "UP" && check "Head node (cmsh)" "PASS" "" || check "Head node (cmsh)" "FAIL" ""
echo "$CMSH_LIST" | grep -q "${TARGET_NODE}" && check "${TARGET_NODE} registered" "PASS" "" || check "${TARGET_NODE} registered" "FAIL" ""

NODE_IP=$(${BCM_SSH} "cmsh -c 'device; use ${TARGET_NODE}; get ip' 2>/dev/null" 2>/dev/null | filter_motd)
check "${TARGET_NODE} IP" "PASS" "$NODE_IP"

NODE_CAT=$(${BCM_SSH} "cmsh -c 'device; use ${TARGET_NODE}; get category' 2>/dev/null" 2>/dev/null | filter_motd)
[[ "$NODE_CAT" == "kairos" ]] && check "${TARGET_NODE} category" "PASS" "$NODE_CAT" || check "${TARGET_NODE} category" "FAIL" "$NODE_CAT"

# Derive the real MAC from cmsh — for local-KVM this equals kairos_vm_mac,
# for remote it's the physical NIC MAC BCM has recorded.
COMPUTE_MAC=$(${BCM_SSH} "cmsh -c 'device; use ${TARGET_NODE}; get mac' 2>/dev/null" 2>/dev/null | filter_motd | tr -d '[:space:]')

INSTALLER_IMG=$(${BCM_SSH} "test -d /cm/images/kairos-installer && echo exists" 2>/dev/null | filter_motd)
[[ "$INSTALLER_IMG" == "exists" ]] && check "kairos-installer image" "PASS" "" || check "kairos-installer image" "FAIL" ""

RAW_IMG=$(${BCM_SSH} "test -f /cm/shared/kairos/disk.raw.lz4 && echo exists" 2>/dev/null | filter_motd)
[[ "$RAW_IMG" == "exists" ]] && check "Kairos raw image" "PASS" "/cm/shared/kairos/disk.raw.lz4" || check "Kairos raw image" "FAIL" ""

# =============================================
# KAIROS COMPUTE NODE
# =============================================
echo ""
echo "============================================"
echo "== Kairos Compute Node =="
echo "============================================"
echo ""

KAIROS_IP=""
if [[ -n "$COMPUTE_MAC" ]]; then
    KAIROS_IP=$(${BCM_SSH} "arp -an 2>/dev/null | grep -i '${COMPUTE_MAC}' | grep -oP '\\d+\\.\\d+\\.\\d+\\.\\d+'" 2>/dev/null | filter_motd)
fi
if [[ -z "$KAIROS_IP" ]]; then
    KAIROS_IP=$(${BCM_SSH} "cmsh -c 'device; use ${TARGET_NODE}; get ip' 2>/dev/null" 2>/dev/null | filter_motd)
fi
echo "Kairos IP: ${KAIROS_IP}"

# Try SSH to Kairos
KAIROS_SSH=""
for attempt in $(seq 1 6); do
    T=$(${BCM_SSH} "ssh ${SSH_OPTS} root@${KAIROS_IP} 'echo CONNECTED' 2>&1" 2>/dev/null | filter_motd || true)
    if [[ "$T" == *"CONNECTED"* ]]; then KAIROS_SSH="ssh ${SSH_OPTS} root@${KAIROS_IP}"; break; fi
    T=$(${BCM_SSH} "sshpass -p ${KAIROS_PASSWORD} ssh ${SSH_OPTS} -o PreferredAuthentications=password -o PubkeyAuthentication=no ${KAIROS_USER}@${KAIROS_IP} 'echo CONNECTED' 2>&1" 2>/dev/null | filter_motd || true)
    if [[ "$T" == *"CONNECTED"* ]]; then
        KAIROS_SSH="sshpass -p ${KAIROS_PASSWORD} ssh ${SSH_OPTS} -o PreferredAuthentications=password -o PubkeyAuthentication=no ${KAIROS_USER}@${KAIROS_IP}"; break
    fi
    (( attempt < 6 )) && sleep 5
done

if [[ -z "$KAIROS_SSH" ]]; then
    check "Kairos SSH" "FAIL" "Cannot reach ${KAIROS_IP}"
    echo ""
    TOTAL=$((PASS+FAIL+WARN))
    echo "============================================"
    echo " PASS: ${PASS}/${TOTAL}  WARN: ${WARN}/${TOTAL}  FAIL: ${FAIL}/${TOTAL}"
    echo "============================================"
    exit 1
fi

run_on_kairos() { ${BCM_SSH} "${KAIROS_SSH} '$1'" 2>/dev/null | filter_motd; }

echo ""
echo "-- Connectivity --"
check "Kairos SSH" "PASS" "${KAIROS_IP}"
${BCM_SSH} "ping -c1 -W3 ${KAIROS_IP}" &>/dev/null && check "Kairos ping" "PASS" "" || check "Kairos ping" "FAIL" ""

echo ""
echo "-- OS --"
OS=$(run_on_kairos 'grep PRETTY_NAME /etc/os-release | cut -d\" -f2' || true)
[[ -n "$OS" ]] && check "OS" "PASS" "$OS" || check "OS" "FAIL" ""

KR=$(run_on_kairos 'grep KAIROS_VERSION /etc/kairos-release 2>/dev/null | head -1 | cut -d= -f2' || true)
[[ -n "$KR" ]] && check "Kairos release" "PASS" "$KR" || check "Kairos release" "FAIL" ""

KA=$(run_on_kairos 'kairos-agent version 2>/dev/null' || true)
[[ -n "$KA" && "$KA" != "MISSING" ]] && check "kairos-agent" "PASS" "$KA" || check "kairos-agent" "FAIL" ""

KERN=$(run_on_kairos 'uname -r' || true)
[[ -n "$KERN" ]] && check "Kernel" "PASS" "$KERN" || check "Kernel" "FAIL" ""

echo ""
echo "-- Network --"
K_IP=$(run_on_kairos 'ip -4 addr show | grep "inet " | grep -v 127.0.0 | head -1 | awk "{print \$2}"' || true)
[[ -n "$K_IP" ]] && check "IP address" "PASS" "$K_IP" || check "IP address" "FAIL" ""

K_GW=$(run_on_kairos 'ip route | grep default | head -1 | awk "{print \$3}"' || true)
[[ -n "$K_GW" ]] && check "Gateway" "PASS" "$K_GW" || check "Gateway" "WARN" "no default route"

K_DNS=$(run_on_kairos 'cat /etc/resolv.conf 2>/dev/null | grep nameserver | head -1 | awk "{print \$2}"' || true)
[[ -n "$K_DNS" ]] && check "DNS resolver" "PASS" "$K_DNS" || check "DNS resolver" "WARN" "no nameserver"

K_DNS_EXT=$(run_on_kairos 'ping -c1 -W3 google.com 2>/dev/null | head -1' || true)
echo "$K_DNS_EXT" | grep -q "bytes of data" && check "External DNS resolution" "PASS" "" || check "External DNS resolution" "WARN" "cannot resolve google.com"

K_INET=$(run_on_kairos 'curl -sk -o /dev/null -w "%{http_code}" --connect-timeout 15 --max-time 30 https://google.com 2>/dev/null' || true)
[[ "$K_INET" == "301" || "$K_INET" == "200" ]] && check "Internet access" "PASS" "HTTP $K_INET" || check "Internet access" "WARN" "HTTP $K_INET"

echo ""
echo "-- Services --"
STYLUS=$(run_on_kairos 'systemctl is-active stylus-agent 2>/dev/null' || true)
[[ "$STYLUS" == "active" ]] && check "stylus-agent" "PASS" "" || check "stylus-agent" "WARN" "status: ${STYLUS:-unknown}"

PALETTE_REG=$(run_on_kairos 'journalctl -u stylus-agent --no-pager 2>/dev/null | grep -c "registering edge host"' | tr -d '[:space:]' || echo 0)
[ "${PALETTE_REG:-0}" -gt 0 ] 2>/dev/null && check "Palette registration" "PASS" "" || check "Palette registration" "WARN" "no registration log entries found"

echo ""
echo "-- Boot --"
CMDLINE=$(run_on_kairos 'cat /proc/cmdline' || true)
echo "$CMDLINE" | grep -q "net.ifnames=0" && check "net.ifnames=0" "PASS" "" || check "net.ifnames=0" "WARN" ""
echo "$CMDLINE" | grep -qE "rd.immucore|rd.cos" && check "Kairos boot chain" "PASS" "" || check "Kairos boot chain" "WARN" ""

echo ""
echo "-- Disk / Partitions --"
for lbl in COS_OEM COS_RECOVERY COS_STATE COS_PERSISTENT; do
    D=$(run_on_kairos "blkid -L $lbl 2>/dev/null" || true)
    [[ -n "$D" && "$D" != "MISSING" ]] && check "$lbl" "PASS" "$D" || check "$lbl" "WARN" "not found"
done

ROOT_RO=$(run_on_kairos 'mount | grep " / " | head -1' || true)
echo "$ROOT_RO" | grep -qE "ro,|ro " && check "Root immutable" "PASS" "" || check "Root immutable" "WARN" ""

DISK_FREE=$(run_on_kairos 'df -h / 2>/dev/null | tail -1 | awk "{print \$4}"' || true)
[[ -n "$DISK_FREE" ]] && check "Disk free" "PASS" "$DISK_FREE" || check "Disk free" "WARN" ""

echo ""
echo "-- Cloud Config --"
OEM=$(run_on_kairos 'ls /oem/*.yaml 2>/dev/null' || true)
[[ -n "$OEM" ]] && check "OEM config" "PASS" "$OEM" || check "OEM config" "FAIL" ""

echo ""
TOTAL=$((PASS+FAIL+WARN))
echo "============================================"
echo " PASS: ${PASS}/${TOTAL}  WARN: ${WARN}/${TOTAL}  FAIL: ${FAIL}/${TOTAL}"
echo "============================================"
(( FAIL > 0 )) && exit 1 || exit 0
